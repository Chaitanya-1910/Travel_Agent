# =============================================================================
#  TravelAI -- Environment Variables Template
#
#  HOW TO USE:
#    1. Copy this file:   cp .env.example .env   (Mac/Linux)
#                         copy .env.example .env  (Windows)
#    2. Fill in the three REQUIRED values marked below
#    3. Never commit .env to Git (it is listed in .gitignore)
#
#  This .env.example file is safe to commit -- it contains no real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
#  IBM Watsonx.ai Credentials  (REQUIRED — you must fill these in)
# -----------------------------------------------------------------------------

# >>> REQUIRED <<<
# Your IBM Cloud API key
# Get it: cloud.ibm.com -> Manage -> Access (IAM) -> API Keys -> Create
IBM_API_KEY=

# >>> REQUIRED <<<
# Your IBM Watsonx.ai Project ID
# Get it: dataplatform.cloud.ibm.com -> Your Project -> Manage -> General
IBM_PROJECT_ID=

# >>> REQUIRED <<<
# Regional Watsonx.ai endpoint — pick the one closest to you:
#   US South : https://us-south.ml.cloud.ibm.com
#   EU DE    : https://eu-de.ml.cloud.ibm.com
#   EU GB    : https://eu-gb.ml.cloud.ibm.com
#   AP North : https://jp-tok.ml.cloud.ibm.com
IBM_URL=

# Model ID — no change needed, already set to a supported model
IBM_MODEL_ID=mistralai/mistral-small-3-1-24b-instruct-2503


# -----------------------------------------------------------------------------
#  Flask Configuration  (defaults work fine for local development)
# -----------------------------------------------------------------------------

# Secret key for Flask sessions — use a strong random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_random_secret_key_here_change_this_in_production

# "development" enables verbose logs; use "production" when deploying
FLASK_ENV=development

# Set to False in production
FLASK_DEBUG=True

# Port the dev server listens on
FLASK_PORT=5000


