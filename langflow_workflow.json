          "display_name": "Prompt Engine",
          "description": "_build_prompt() — Mistral [INST] format with AGENT_INSTRUCTIONS (persona, response_style, budget_philosophy, safety_guidelines, itinerary_style, accommodation_style, food_philosophy, personalisation, culture_guidance, chat_rules)",
          "template": {
