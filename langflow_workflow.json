      "id": "sanitizer",
      "type": "PythonFunctionTool",
      "position": { "x": 320, "y": 380 },
      "data": {
        "type": "PythonFunctionTool",
        "node": {
          "display_name": "Input Sanitizer",
          "description": "html.escape() · strip null bytes · 2000 char limit · sanitize_input()",
          "template": {
            "code": {
              "type": "code",
              "display_name": "sanitize_input",
              "value": "import html\ndef sanitize_input(text: str) -> str:\n    if not isinstance(text, str):\n        return ''\n    text = text.replace('\\x00', '')\n    text = html.escape(text.strip())\n    return text[:2000]"
            }
          }
        }
      }
    },
    {
      "id": "offtopic-guard",
      "type": "PythonFunctionTool",
      "position": { "x": 320, "y": 560 },
      "data": {
        "type": "PythonFunctionTool",
        "node": {
          "display_name": "Off-Topic Guard",
          "description": "Regex gate — blocks non-travel queries before reaching the LLM. Patterns: who is, father of, born in, calculate, crypto, stock price, tell me a joke",
          "template": {
            "code": {
              "type": "code",
              "display_name": "_is_travel_related",
              "value": "import re\nPATTERNS = [r'\\bwho\\s+is\\b', r'\\bfather\\s+of\\b', r'\\bborn\\s+in\\b', r'\\bcalculat', r'\\bcrypto\\b', r'\\bstock\\s+price\\b', r'\\btell\\s+me\\s+a\\s+joke\\b']\ndef is_travel_related(msg):\n    return not any(re.search(p, msg.lower()) for p in PATTERNS)"
            }
          }
        }
      }
    },
