              "type": "prompt",
              "display_name": "Prompt Template",
              "value": "[INST] {persona}\n\n{response_style}\n\n{system_context}\n\n{user_request} [/INST]"
            },
            "persona": {
              "type": "str",
              "display_name": "Persona",
              "value": "You are an expert AI Travel Planner with 20+ years of global travel consulting experience."
            }
          }
        }
      }
    },
    {
      "id": "orchestrator",
      "type": "PythonFunctionTool",
      "position": { "x": 860, "y": 380 },
      "data": {
        "type": "PythonFunctionTool",
        "node": {
          "display_name": "Agent Orchestrator",
          "description": "TravelAgentOrchestrator — ThreadPoolExecutor(8 workers) · stagger 0.4s · as_completed() · EnvironmentError=abort · agent fail=isolated",
          "template": {
            "code": {
              "type": "code",
              "display_name": "plan_trip",
              "value": "from concurrent.futures import ThreadPoolExecutor, as_completed\nimport time\ndef plan_trip(trip_data, agents):\n    results = {}\n    with ThreadPoolExecutor(max_workers=8) as pool:\n        futures = {pool.submit(fn, trip_data, idx*0.4): key for idx,(key,fn) in enumerate(agents)}\n        for f in as_completed(futures):\n            key, result = f.result()\n            results[key] = result\n    return results"
            }
          }
        }
      }
    },
